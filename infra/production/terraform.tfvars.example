# DigitalOcean
do_token     = "dop_v1_your_token_here"
region       = "sgp1"
cluster_name = "sub2api"
k8s_version  = "1.34"
node_size    = "s-2vcpu-4gb"
min_nodes    = 1
max_nodes    = 3

# Kubernetes bootstrap
letsencrypt_email = "admin@yourdomain.com"

# Cloudflare DNS
cloudflare_api_token = "your_cloudflare_api_token_here"
cloudflare_zone_id   = "your_zone_id_here"
domain_suffix        = "do-prod.yourdomain.com"
cloudflare_proxied   = true

# Managed PostgreSQL (optional, default false)
enable_managed_database = false
# db_size               = "db-s-1vcpu-1gb"

# Observability storage (optional, default false)
# Creates Cloudflare R2 buckets for Tempo (traces) and Loki (logs)
enable_observability_storage = false
# cloudflare_account_id = "your_cloudflare_account_id"

# Sub2API application (required)
app_image_tag = "v0.1.1"
# admin_email = "admin@sub2api.local"

# Monitoring stack (optional, default false)
# Requires enable_observability_storage = true for R2 buckets
enable_monitoring = false
# r2_access_key   = "your_r2_access_key"
# r2_secret_key   = "your_r2_secret_key"
